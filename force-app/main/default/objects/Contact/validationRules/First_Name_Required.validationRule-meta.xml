<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>First_Name_Required</fullName>
    <active>true</active>
    <description>If First Name is blank, display a validation message.</description>
    <errorConditionFormula>ISBLANK( FirstName )</errorConditionFormula>
    <errorMessage>Please enter First Name.</errorMessage>
</ValidationRule>
