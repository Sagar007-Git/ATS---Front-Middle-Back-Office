<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Prxm Dynamic Record Creator</masterLabel>
    <description>Enterprise Generic Component to dynamically render and populate a record creation form based on Custom Metadata.</description>

    <!-- Define where the component can be used by an Admin -->
    <targets>
        <target>lightning__RecordPage</target>
        <target>lightning__AppPage</target>
        <target>lightning__HomePage</target>
        <target>lightning__FlowScreen</target>
        <target>lightning__RecordAction</target>
    </targets>

    <targetConfigs>
        <!-- App Builder Properties (Configures variables on Record, App, Home Pages) -->
        <targetConfig targets="lightning__RecordPage, lightning__AppPage, lightning__HomePage">
            <!-- Allow the Admin to enter the Action_Name__c from the CMDT -->
            <property name="actionName" type="String" label="CMDT Action Name" description="The exact developer name of the Action Config mapped in metadata (e.g. Prx_Convert_To_Placement)" required="true"/>
            
            <!-- Contextual Properties based on page types -->
            <supportedFormFactors>
                <supportedFormFactor type="Large"/>
                <supportedFormFactor type="Small"/>
            </supportedFormFactors>
        </targetConfig>

        <!-- Flow Builder Properties -->
        <targetConfig targets="lightning__FlowScreen">
            <property name="recordId" type="String" label="Source Record Id" description="The contextual ID starting this action" role="inputOnly"/>
            <property name="actionName" type="String" label="CMDT Action Name" description="The exact DeveloperName in the Mapping Metadata" role="inputOnly" required="true"/>
        </targetConfig>

        <!-- Quick Actions Properties -->
        <targetConfig targets="lightning__RecordAction">
            <actionType>ScreenAction</actionType>
        </targetConfig>
    </targetConfigs>

</LightningComponentBundle>