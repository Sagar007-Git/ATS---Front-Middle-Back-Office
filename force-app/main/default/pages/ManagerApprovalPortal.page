<apex:page showHeader="false" sidebar="false" standardStylesheets="false" applyBodyTag="false">
    <head>
        <title>Approval Portal</title>
        <apex:includeLightning />
        <style>
            /* Clean background to match our SaaS UI */
            body { 
                background-color: #F4F5F7; 
                margin: 0; 
                padding: 0; 
                font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            }
        </style>
    </head>
    
    <body>
        <div id="lwc-container"></div>

        <script>
            // 1. Initialize the Aura App (ApprovalHubApp)
            $Lightning.use("c:ApprovalHubApp", function() {
                
                // 2. Inject the LWC (timesheetApprovalHub) into the div above
                $Lightning.createComponent(
                    "c:timesheetApprovalHub", 
                    { 
                        // You can pass parameters into your LWC's @api properties here if needed in the future
                    },
                    "lwc-container", // The ID of the div
                    function(cmp) {
                        console.log("Enterprise Approval Hub loaded successfully via Lightning Out!");
                    }
                );
            });
        </script>
    </body>
</apex:page>